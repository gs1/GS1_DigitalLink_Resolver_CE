# ---------------------------------------------------------------
# GS1 Digital Link Resolver CE — Environment Configuration
# ---------------------------------------------------------------
# Copy this file to .env and fill in your own values.
# NEVER commit the .env file to version control.
# ---------------------------------------------------------------

# MongoDB root credentials (used by the database-service container on first run)
MONGO_INITDB_ROOT_USERNAME=change_me_username
MONGO_INITDB_ROOT_PASSWORD=change_me_password

# MongoDB connection string (used by data-entry-service and web-service)
# Must match the username and password above.
MONGO_URI=mongodb://change_me_username:change_me_password@database-service:27017

# Bearer token required for data-entry API authentication
SESSION_TOKEN=change_me_to_a_long_random_string
