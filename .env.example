# ---------------------------------------------------------------
# GS1 Digital Link Resolver CE — Environment Configuration
# ---------------------------------------------------------------
# Copy this file to .env and fill in your own values.
# NEVER commit the .env file to version control.
# ---------------------------------------------------------------

# MongoDB root credentials (used by the database-service container on first run)
# MONGO_INITDB_ROOT_USERNAME=change_me_username
# MONGO_INITDB_ROOT_PASSWORD=change_me_password

# MongoDB connection string (used by data-entry-service and web-service)
# Must match the username and password above.
# MONGO_URI=mongodb://change_me_username:change_me_password@database-service:27017

# Bearer token required for data-entry API authentication
# SESSION_TOKEN=change_me_to_a_long_random_string


# These example credentials will get you up and running quickly to test the application
# 'out of the box' on your development machine using docker compose.
MONGO_INITDB_ROOT_USERNAME=gs1resolver
MONGO_INITDB_ROOT_PASSWORD=gs1resolver

# MongoDB connection string running local Docker (used by data-entry-service and web-service)
MONGO_URI=mongodb://gs1resolver:gs1resolver@database-service:27017

# Bearer token required for data-entry API authentication.
# Try not to use in this particular value in production! :-)
SESSION_TOKEN=secret